@model Clinica.Web.Models.PaginatedList<Clinica.Domain.Entities.ObraSocial>

@{
    ViewData["Title"] = "Obras Sociales";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Obras Sociales</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nueva Obra Social
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0 me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="DeleteMultiple" method="post">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-muted">Listado</h5>
            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Está seguro de eliminar las obras sociales seleccionadas?');">
                <i class="bi bi-trash"></i> Eliminar Seleccionados
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4" style="width: 40px;">
                                <input type="checkbox" class="form-check-input" id="selectAll" />
                            </th>
                            <th>Nombre</th>
                            <th>Código</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">No hay obras sociales registradas.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <input type="checkbox" class="form-check-input select-item" name="ids" value="@item.ObraSocialId" />
                            </td>
                            <td><strong>@item.Nombre</strong></td>
                            <td>@item.Codigo</td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.ObraSocialId" class="btn btn-sm btn-outline-primary me-2">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.ObraSocialId" class="btn btn-sm btn-outline-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
</form>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Navegación de páginas" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)">Anterior</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)">Siguiente</a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const selectAll = document.getElementById('selectAll');
            const items = document.querySelectorAll('.select-item');
            
            if (selectAll) {
                selectAll.addEventListener('change', function () {
                    items.forEach(item => {
                        item.checked = selectAll.checked;
                    });
                });
            }
        });
    </script>
}
