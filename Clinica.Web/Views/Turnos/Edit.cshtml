@model Clinica.Domain.Entities.Turno

@{
    ViewData["Title"] = "Editar turno";
}

<h1>Editar turno</h1>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input type="hidden" asp-for="TurnoId" />

    <div class="mb-3">
        <label class="form-label">Médico</label>
        <select asp-for="MedicoId" class="form-select select2-medico" data-placeholder="Seleccionar médico">
            @{
                var medicoItems = ViewBag.MedicoId as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
                if (medicoItems != null)
                {
                    var sel = medicoItems.FirstOrDefault(i => i.Selected);
                    if (sel != null)
                    {
                        <option value="@sel.Value" selected>@sel.Text</option>
                    }
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Paciente</label>
        <select asp-for="PacienteId" class="form-select select2-paciente" data-placeholder="(Sin paciente asignado)">
            <option value=""></option>
            @{
                var pacienteItems = ViewBag.PacienteId as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
                if (pacienteItems != null)
                {
                    var selPac = pacienteItems.FirstOrDefault(i => i.Selected);
                    if (selPac != null)
                    {
                        <option value="@selPac.Value" selected>@selPac.Text</option>
                    }
                }
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="FechaHoraInicio" class="form-label"></label>
        <input asp-for="FechaHoraInicio" class="form-control" type="datetime-local" />
        <span asp-validation-for="FechaHoraInicio" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="FechaHoraFin" class="form-label"></label>
        <input asp-for="FechaHoraFin" class="form-control" type="datetime-local" />
        <span asp-validation-for="FechaHoraFin" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Estado" class="form-label"></label>
        <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<Clinica.Domain.Entities.EstadoTurno>()"></select>
    </div>

    <div class="mb-3">
        <label asp-for="MotivoConsulta" class="form-label"></label>
        <input asp-for="MotivoConsulta" class="form-control" />
        <span asp-validation-for="MotivoConsulta" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @{await Html.RenderPartialAsync("_Select2Scripts");}
}
